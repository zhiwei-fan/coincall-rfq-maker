# One .env can serve both processes. The maker and taker each validate only
# their own credential pair.

# --- MAKER ---
API_KEY=""
API_SECRET=""

WS_URL="wss://betaws.seizeyouralpha.com/options"

# DRY_RUN defaults to true: quotes are computed and logged but never submitted.
DRY_RUN=true
CANCEL_ALL_ON_START=true
CANCEL_ALL_ON_STOP=true

HEARTBEAT_INTERVAL_SECONDS=5
PRICING_REFRESH_SECONDS=5
QUOTE_REFRESH_SECONDS=10
PRICE_MOVE_THRESHOLD=0.001

MAX_QUOTE_NOTIONAL_USD=1000000
MAX_LEG_QTY=100
MIN_TIME_TO_EXPIRY_HOURS=1
STALE_MARKET_DATA_SECONDS=30

BID_VOL=0.20
ASK_VOL=2.00
RISK_FREE_RATE=0.05

DB_PATH="rfq_maker.db"
LOG_LEVEL=INFO

# --- TAKER ---
# TAKER_API_KEY/TAKER_API_SECRET are a SEPARATE taker account and are REQUIRED
# to run `rfq-taker`. The taker will NOT fall back to the maker API_KEY/API_SECRET.
TAKER_API_KEY=""
TAKER_API_SECRET=""

# HARD cap on the gross premium an `rfq-taker execute`/`trade` may accept. This
# cap refuses execution even when --yes is passed.
TAKER_MAX_NOTIONAL_USD=5000

# Append-only JSONL audit log for the taker TRADE path (create/execute/cancel).
# A taker cannot list its own RFQs via the API, so this is the orphan-recovery
# record. `~` is expanded; the parent directory is created if missing.
TAKER_AUDIT_PATH=~/.rfq-taker/audit.jsonl

# --- SHARED ---
REST_BASE_URL="https://betaapi.coincall.com"
